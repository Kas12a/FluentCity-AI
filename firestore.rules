rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public curriculum content can be read by everyone
    match /curriculum/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // A user can read and write only their own document under users/{userId}
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // A user can read and write only their own subcollections
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // No user can read another user’s profile, practice sessions, mistakes, reviews, or progress
    // (This is implicitly handled by the rule above since match /users/{userId} requires auth.uid == userId)
  }
}
