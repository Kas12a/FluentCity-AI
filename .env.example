# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Public Web API Key from Firebase Console
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY

# FIREBASE_APPLICATION_ID: App ID from Firebase Console (e.g. 1:123456789:android:abcdef)
FIREBASE_APPLICATION_ID=YOUR_FIREBASE_APPLICATION_ID

# FIREBASE_PROJECT_ID: Project ID from Firebase Console (e.g. my-firebase-project)
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
